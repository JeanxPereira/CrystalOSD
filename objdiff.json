{
  "$schema": "https://raw.githubusercontent.com/encounter/objdiff/main/config.schema.json",
  "custom_make": "make",
  "custom_args": ["-j4"],
  "build_target": true,
  "build_base": false,
  "watch_patterns": ["*.c", "*.h", "*.s", "*.S", "Makefile"],
  "ignore_patterns": ["reference/**/*", ".git/**/*"],
  "units": [
    { "name": "browser/browser", "target_path": "build/target/browser/browser.o", "base_path": null },
    { "name": "clock/clock",     "target_path": "build/target/clock/clock.o",     "base_path": null },
    { "name": "config/config",   "target_path": "build/target/config/config.o",   "base_path": null },
    { "name": "core/core",       "target_path": "build/target/core/core.o",        "base_path": null },
    { "name": "graph/graph",     "target_path": "build/target/graph/graph.o",      "base_path": null },
    { "name": "module/module",   "target_path": "build/target/module/module.o",   "base_path": null },
    { "name": "opening/opening", "target_path": "build/target/opening/opening.o", "base_path": null },
    { "name": "sound/sound",     "target_path": "build/target/sound/sound.o",     "base_path": null }
  ]
}